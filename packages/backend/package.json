{
  "name": "@vao/backend",
  "version": "0.1.0",
  "description": "Backend du projet VAO",
  "author": "orgs/SocialGouv/teams/vao",
  "license": "Apache-2.0",
  "main": "src/index.js",
  "scripts": {
    "lint": "eslint ./src",
    "lint:fix": "corepack pnpm lint --fix",
    "dev": "nodemon --inspect=0.0.0.0:9229 src/index.js",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --config=jest.config.js --runInBand",
    "test:debug": "pnpm test --debug --detectOpenHandles",
    "test:watch": "pnpm test --watch",
    "test:coverage": "pnpm test --coverage",
    "build": "tsc -b ./tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": "pnpm lint",
    "src/**/*.ts": "zsh -c 'pnpm build'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@sentry/node": "^8.49.0",
    "@sentry/profiling-node": "^8.49.0",
    "@types/supertest": "^7.2.0",
    "@vao/shared-bridge": "workspace:^",
    "axios": "^1.16.1",
    "body-parser": "~1.20.3",
    "cookie-parser": "^1.4.6",
    "cors": "~2.8.5",
    "cron": "~3.1.7",
    "dayjs": "catalog:",
    "debug": "catalog:",
    "express": "~4.21.0",
    "file-type": "^19.6.0",
    "form-data": "^4.0.1",
    "helmet": "~8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "catalog:",
    "multer": "catalog:",
    "nodemailer": "catalog:",
    "pdfmake": "^0.2.10",
    "pg": "catalog:",
    "pg-format": "~1.0.4",
    "proj4": "^2.15.0",
    "ufo": "^1.5.4",
    "yup": "catalog:"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/s3mock": "^11.14.0",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^8.0.0",
    "@types/nodemailer-smtp-transport": "^2.7.8",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "eslint": "catalog:",
    "jest": "catalog:",
    "nodemon": "catalog:",
    "pdf-lib": "^1.17.1",
    "prettier": "catalog:",
    "supertest": "catalog:",
    "ts-jest": "catalog:",
    "ts-node": "^10.9.2",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}