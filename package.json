{
  "name": "vao",
  "version": "0.1.0",
  "description": "Vacances Adaptées Organisées",
  "author": "orgs/SocialGouv/teams/vao",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:all": "corepack pnpm run lint:backend && corepack pnpm run lint:frontend-usagers && corepack pnpm run lint:frontend-bo && corepack pnpm run lint:shared-ui && corepack pnpm run lint:api && corepack pnpm run lint:cron",
    "lint:all:fix": "corepack pnpm run lint:backend --fix && corepack pnpm run lint:frontend-usagers --fix && corepack pnpm run lint:frontend-bo --fix && corepack pnpm run lint:shared-ui --fix && corepack pnpm run lint:api --fix && corepack pnpm run lint:cron --fix",
    "lint:api": "corepack pnpm --dir ./packages/external-api run lint",
    "lint:backend": "corepack pnpm --dir ./packages/backend run lint",
    "lint:cron": "corepack pnpm --dir ./packages/cron run lint",
    "lint:frontend-usagers": "corepack pnpm --dir ./packages/frontend-usagers run lint",
    "lint:frontend-bo": "corepack pnpm --dir ./packages/frontend-bo run lint",
    "lint:shared-ui": "corepack pnpm --dir ./packages/shared-ui run lint && corepack pnpm --dir ./packages/shared-bridge run lint",
    "knex": "POSTGRES_HOST=localhost POSTGRES_PORT=5436 env-cmd --no-override knex --cwd ./packages/migrations/src",
    "test:unit:all": "corepack pnpm run test:unit:api && corepack pnpm run test:unit:backend && corepack pnpm run test:unit:shared-bridge && corepack pnpm run test:unit:cron",
    "test:unit:api": "corepack pnpm --filter @vao/external-api test:cov",
    "test:unit:backend": "corepack pnpm --filter @vao/backend test:coverage",
    "test:unit:cron": "corepack pnpm --filter @vao/cron test:coverage",
    "test:unit:shared-bridge": "corepack pnpm --filter @vao/shared-bridge test:coverage",
    "test:unit:frontend": "corepack pnpm run test:unit:frontend-bo && corepack pnpm run test:unit:frontend-usagers",
    "test:unit:frontend-bo": "corepack pnpm --filter @vao/frontend-bo test",
    "test:unit:frontend-usagers": "corepack pnpm --filter @vao/frontend-usagers test",
    "tests:e2e": "E2E_LOCAL=true playwright test",
    "tests:e2e:ui": "E2E_LOCAL=true playwright test --ui",
    "clean": "corepack pnpm --dir ./packages/frontend-usagers clean && corepack pnpm --dir ./packages/frontend-bo clean && rm -rf node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@playwright/test": "^1.50.1",
    "@socialgouv/eslint-config-recommended": "^1.131.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.10.0",
    "@types/pg-format": "^1.0.5",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "env-cmd": "~10.1.0",
    "husky": "^9.0.10",
    "jsdom": "^27.4.0",
    "lint-staged": "^15.2.1",
    "node-talisman": "^1.29.22",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.46.3"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "eslint-plugin-jest": "^28.11.0",
      "eslint-plugin-import": "^2.32.0",
      "@nuxt/kit": "^3.21.6",
      "form-data@<2.5.4": "^2.5.5",
      "h3": "^1.15.9",
      "multer@<2.1.1": "^2.1.1",
      "protobufjs": "^7.5.8"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@sentry/cli",
      "@sentry/profiling-node",
      "esbuild"
    ]
  }
}